APP_NAME=Dev Portfolio App
APP_VERSION=1.0.0
DEBUG=True
API_V1_PREFIX=/api/v1

# Local Docker Compose
DATABASE_URL=postgresql+psycopg://db_username:db_password@db:5432/db_name

# EC2 / RDS example
# DATABASE_URL=postgresql+psycopg://db_username:db_password@your-rds-endpoint:5432/db_name?sslmode=require

SECRET_KEY=your-dev-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
